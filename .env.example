# QNAS — copy to .env and edit: cp .env.example .env

# NSGA-II
POP_SIZE=12
N_GEN=6
SEED=42
WORKERS_PER_GPU=2
# Training (per candidate)
EVAL_EPOCHS=2
BATCH_SIZE=256

# Dataset: mnist | fashion-mnist | cifar10 | svhn | iris | heart-failure
DATASET=mnist
DATA_ROOT=./data

# Quantum search space
NQ_MIN=2
NQ_MAX=8
DEPTH_MIN=1
DEPTH_MAX=4
LR_MIN=0.001
LR_MAX=0.01
SHOTS=0

FINAL_TRAIN_EPOCHS=10
FINAL_TRAIN_GPU=0

# Where run logs are written (CSVs, progress.log, .env snapshot)
LOG_DIR=./logs
