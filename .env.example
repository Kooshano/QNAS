# QNAS — copy to .env and edit: cp .env.example .env
#
# After NSGA-II, all Pareto-optimal architectures are fully retrained
# and their weights are saved to weights/{run_folder}/.

# ========================================
# NSGA-II Search / Evolution
# ========================================
POP_SIZE=12
N_GEN=6
SEED=42

# ========================================
# Per-Candidate Evaluation (during NSGA-II)
# ========================================
EVAL_EPOCHS=2
WORKERS_PER_GPU=6
# 0 = full epoch; >0 = cap batches per epoch for faster search
MAX_TRAIN_BATCHES=0
MAX_VAL_BATCHES=0
# 0 = adjoint (exact gradients); >0 = shot-based differentiation
SHOTS=0

# ========================================
# Final Retraining (all Pareto-optimal, after NSGA-II)
# ========================================
FINAL_TRAIN_EPOCHS=12
FINAL_SHOTS=0
# Parallel workers per GPU during final Pareto retraining
FINAL_WORKERS_PER_GPU=4
# Comma-separated GPU IDs; unset = use all available GPUs
# FINAL_TRAIN_GPUS=0,1

# ========================================
# Dataset & Data Loader
# ========================================
# mnist | fashion-mnist | cifar10 | svhn | emnist | iris | heart-failure
DATASET=mnist
DATA_ROOT=./data
BATCH_SIZE=1024
# 0 = full dataset
TRAIN_SUBSET_SIZE=0
VAL_SUBSET_SIZE=0
FINAL_TRAIN_SUBSET_SIZE=0
FINAL_VAL_SUBSET_SIZE=0
TRAIN_DROP_LAST=false

# ========================================
# Classical Head
# ========================================
PRE_CLASSICAL_LAYERS=1
POST_CLASSICAL_LAYERS=1
CLASSICAL_HIDDEN_DIM=256
# ANGLE_EMBEDDING_ACTIVATION=none

# ========================================
# Quantum Search Space
# ========================================
ALLOWED_EMBEDDINGS=angle-x,angle-y,angle-z,amplitude
NQ_MIN=2
NQ_MAX=8
DEPTH_MIN=1
DEPTH_MAX=4
ERANGE_MIN=1
ERANGE_MAX=5
LR_MIN=0.001
LR_MAX=0.01
# CNOT pattern indices: 0=all, 1=odd, 2=even, 3=none
CMODE_MIN=0
CMODE_MAX=3
# Wire-cutting target qubits (0 = unconstrained)
CUT_TARGET_QUBITS=4

# ========================================
# Pareto Selection
# ========================================
# f1_1_minus_acc  : 1 − accuracy (minimise)
# f2_circuit_cost : seconds per sample (minimise)
# f3_n_subcircuits: subcircuits after wire cutting (minimise; requires CUT_TARGET_QUBITS>0)
PARETO_OBJECTIVES=f1_1_minus_acc,f2_circuit_cost,f3_n_subcircuits

# ========================================
# Accuracy Prediction (optional)
# ========================================
# PREDICT_FINAL_ACC_ENABLED=true
# PREDICT_FINAL_ACC_SLOPE=0.95
# PREDICT_FINAL_ACC_INTERCEPT=5.0
# PREDICT_FINAL_ACC_CHECKPOINT_FILE=

# ========================================
# Checkpoint Validation (optional)
# ========================================
CHECKPOINT_VALIDATION_ENABLED=false
CHECKPOINT_NSGA_ENABLED=false
CHECKPOINT_FINAL_ENABLED=false
CHECKPOINT_CORRELATION_ENABLED=false
CHECKPOINT_TRAIN_SIZES=full
CHECKPOINT_TARGET_EPOCHS=1,3,5,10

# ========================================
# Logging
# ========================================
LOG_DIR=./logs
# RESUME_LOGS=0